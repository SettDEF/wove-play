{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wove",
  "version": "0.2.3",
  "identifier": "com.wavr.play",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wove",
        "width": 420,
        "height": 820,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "backgroundColor": "#0F1411"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Music",
    "shortDescription": "Material 3 music player",
    "longDescription": "Wove — a Material 3 music player with a live visualizer, parametric EQ, and on-device taste mixes.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": { "desktopTemplate": "wove.desktop" }
    }
  },
  "plugins": {}
}
